# =========================
# GENERAL CONFIGURATION
# =========================

# System timezone
TZ=Europe/Madrid


# =========================
# DNS CONFIGURATION
# =========================

# Primary and secondary upstream DNS providers
# Example: Cloudflare (1.1.1.1), Google (8.8.8.8), etc.
PIHOLE_DNS_1=1.1.1.1
PIHOLE_DNS_2=1.0.0.1

# Pi-hole internal upstream configuration (do not modify unless needed)
FTLCONF_dns_upstreams=${PIHOLE_DNS_1},${PIHOLE_DNS_2}


# =========================
# SECURITY
# =========================

# Web interface password (REQUIRED)
# Replace with a strong password before deployment
FTLCONF_webserver_api_password=YOUR_STRONG_PASSWORD


# =========================
# DNS BEHAVIOR
# =========================

# Restrict DNS queries to local network only
DNSMASQ_LISTENING=local