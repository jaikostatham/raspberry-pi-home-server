# =========================
# WireGuard (wg-easy) config
# =========================

# Public endpoint (DuckDNS / domain)
WG_HOST=vpn.example.com

# WireGuard UDP port
WG_PORT=51820

# VPN subnet (client address pool)
WG_DEFAULT_ADDRESS=10.8.0.x

# Internal DNS (Pi-hole in LAN)
WG_DEFAULT_DNS=192.168.1.10

# Allowed networks (LAN + VPN)
WG_ALLOWED_IPS=192.168.1.0/24,10.8.0.0/24

# Keepalive for NAT traversal
WG_PERSISTENT_KEEPALIVE=25

# Web UI port (used in docker-compose)
WG_UI_PORT=51821

# Web UI password (hashed)
# Generate with:
# docker run ghcr.io/wg-easy/wg-easy wgpw YOUR_PASSWORD
WG_PASSWORD=YOUR_HASHED_PASSWORD

# MTU (optional tuning)
WG_MTU=1420