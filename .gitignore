# Pi-hole data
docker/pihole/data/*
!docker/pihole/data/.gitkeep

# WireGuard sensitive data
docker/wireguard/config/*
!docker/wireguard/config/.gitkeep

# DuckDNS data
docker/duckdns/config/*
!docker/duckdns/config/.gitkeep

# Portainer data
docker/portainer/data/*
!docker/portainer/data/.gitkeep

# System configs (sensitive)
configs/*
!configs/*/
!configs/**/.gitkeep

# ENV FILES (SENSITIVE)
.env
.env.*
!.env.example

# DATA
data/
*.db
*.sqlite

# LOGS
logs/
*.log

# OS / EDITOR
.DS_Store
Thumbs.db
.vscode/
.idea/

# BACKUPS
*.bak
*.tar
*.gz

